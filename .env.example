ADMIN_PASSWORD=change-me
SESSION_SECRET=replace-with-a-long-random-string

# Provisioned automatically once a Vercel Blob store is created and linked
# to this project (Storage tab, or `vercel blob store add`). Pull it into
# .env.local locally with: vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=

# From the Stripe dashboard (Developers > API keys). Use test-mode keys
# (sk_test_… / pk_test_…) until you're ready to go live. Checkout returns a
# clear "not configured" error to shoppers if these are left blank.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# From the Stripe dashboard once you create a webhook endpoint pointing at
# <your-domain>/api/webhooks/stripe, listening for checkout.session.completed.
STRIPE_WEBHOOK_SECRET=

# Flat shipping rates in cents, charged in addition to item prices.
NEXT_PUBLIC_SHIPPING_RATE_FRANCE_CENTS=590
NEXT_PUBLIC_SHIPPING_RATE_INTL_CENTS=1890

# Absolute site URL, used to build Stripe's success/cancel redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
